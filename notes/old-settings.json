    "workbench.iconTheme": "material-icon-theme",
    "workbench.list.horizontalScrolling": true,
    "workbench.preferredHighContrastColorTheme": "Tomorrow Night Blue",
    "workbench.preferredLightColorTheme": "Tomorrow Night Blue",
    "workbench.startupEditor": "none",
    "workbench.tree.indent": 4,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.colorCustomizations": {
        "list.activeSelectionBackground": "#7bff46b2",
        "list.activeSelectionForeground": "#000000",
        "list.inactiveSelectionBackground": "#7bff46b2",
        "list.inactiveSelectionForeground": "#000000",
        "editor.findMatchForeground": "#000000", // Example: Yellow text for current find match
        "editor.findMatchBackground": "#00ff00", // Color for the active find match
        "editor.findMatchHighlightForeground": "#000000", // Example: Orange text for other find matches
        "editor.findMatchHighlightBackground": "#7bff46b2" // Color for other find matches
