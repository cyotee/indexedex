    ],
    "redhat.telemetry.enabled": false,
    "rsp-ui.enableStartServerOnActivation": [
        {
        "id": "redhat.vscode-server-connector",
        "name": "Red Hat Server Connector",
        "startOnActivation": true
        }
    ],
    "solidity-va.test.defaultUnittestTemplate": "hardhat",
    "solidity-va.uml.actors.enable": true,
    "solidity.compileUsingRemoteVersion": "v0.8.30",
    "solidity.compilerOptimization": 200,
    // "solidity.formatter": "none",
    "solidity.packageDefaultDependenciesContractsDirectory": "src",
    "solidity.packageDefaultDependenciesDirectory": "lib",
    "solidity.linter": "solhint",
    "solidity.solhintRules": {
        "max-line-length": "disable"
    },
    "solidity.remappings": [
        "forge-std/=lib/forge-std/src/",
        "@openzeppelin/contracts/=dependencies/openzeppelin-contracts/contracts/",
        "@solady/=dependencies/solady/src/",
        "permit2/=dependencies/permit2/",
        "@balancer-labs/v3-interfaces/=dependencies/balancer-v3-monorepo/pkg/interfaces/",
        "@balancer-labs/v3-vault/=dependencies/balancer-v3-monorepo/pkg/vault/",
        "@balancer-labs/v3-solidity-utils/=dependencies/balancer-v3-monorepo/pkg/solidity-utils/",
        "@balancer-labs/v3-pool-utils/=dependencies/balancer-v3-monorepo/pkg/pool-utils/",
        "@balancer-labs/v3-reclamm/=dependencies/reclamm"
    ],
    "svg.preview.mode": "img",
    "tabnine.experimentalAutoImports": true,
    "task.autoDetect": "off",
    "taskExplorer.autoRefresh": false,
    "taskExplorer.enableAnsiconForAnt": false,
    "taskExplorer.enableExplorerView": false,
    "taskExplorer.enabledTasks": {
        "ant": false,
        "bash": false,
        "composer": false,
        "gradle": false,
        "grunt": false,
        "gulp": false,
        "make": false,
        "maven": false,
        "perl": false,
        "powershell": false,
        "ruby": false
